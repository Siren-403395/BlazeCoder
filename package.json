{
  "name": "coding-agent",
  "version": "0.1.0",
  "private": true,
  "description": "A Claude-Code-style command-line coding agent: an agentic harness (loop + tools + context engineering) that edits real files and runs real commands in a local terminal (TUI).",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "zephyrcode": "pnpm --filter @coding-agent/cli zephyrcode",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}

{
  "name": "@blazecoder/host",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node/OS host wiring shared by every blazecoder UI host (TUI, GUI): model gateway + sandbox + file stores + config/settings loaders + buildRuntime, behind the portable agent-core kernel. Contains no UI code.",
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "lint": "echo \"(no linter configured for @blazecoder/host)\""
  },
  "dependencies": {
    "@blazecoder/core": "workspace:*",
    "@blazecoder/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

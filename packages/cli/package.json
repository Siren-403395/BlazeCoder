{
  "name": "@blazecoder/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "blazecoder": "./dist/blazecoder.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "blazecoder": "tsx src/main.tsx",
    "dev": "tsx src/main.tsx",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "lint": "echo \"(no linter configured for @blazecoder/cli)\""
  },
  "dependencies": {
    "@blazecoder/core": "workspace:*",
    "@blazecoder/host": "workspace:*",
    "@blazecoder/shared": "workspace:*",
    "ink": "^5",
    "ink-spinner": "^5",
    "ink-text-input": "^6",
    "marked": "^12.0.2",
    "marked-terminal": "^7.3.0",
    "react": "^18"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18",
    "ink-testing-library": "^4",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

{
  "name": "@coding-agent/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "ca": "./src/main.tsx"
  },
  "scripts": {
    "ca": "tsx src/main.tsx",
    "dev": "tsx src/main.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "lint": "echo \"(no linter configured for @coding-agent/cli)\""
  },
  "dependencies": {
    "@coding-agent/core": "workspace:*",
    "@coding-agent/shared": "workspace:*",
    "ink": "^5",
    "ink-spinner": "^5",
    "ink-text-input": "^6",
    "react": "^18"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18",
    "ink-testing-library": "^4",
    "tsx": "^4",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

# ── Model provider (DeepSeek, OpenAI-compatible chat/completions + tool calling) ──
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Backend server ──
PORT=8787
# Comma-separated origins allowed to hit the agent API (the web dev server).
CORS_ORIGIN=http://localhost:5173

# ── Agent runtime caps (safety backstops; the agent loop is model-decided but OURS-bounded) ──
AGENT_MAX_TURNS=24
AGENT_MAX_BUDGET_USD=1.0
# Context window the model actually supports (DeepSeek), used by the budget gauge + compaction triggers.
AGENT_CONTEXT_TOKENS=65536

# ── Persistence (filesystem session/memory store lives under here) ──
DATA_DIR=.data

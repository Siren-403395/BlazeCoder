# zephyrcode configuration. Copy to `.env` (gitignored) or let `./install.sh` write
# ~/.zephyrcode/.env for you. Precedence (lowest → highest):
#   ~/.zephyrcode/.env   <   ./.env (this project)   <   the real environment
# Only DEEPSEEK_API_KEY is required; everything else has a sensible default.

# ── Model provider (DeepSeek; OpenAI-compatible chat/completions + tool calling) ──
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# The default. Set this to any model your key can call (e.g. deepseek-chat, deepseek-reasoner).
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Agent runtime caps (safety backstops; the loop is model-decided but OURS-bounded) ──
AGENT_MAX_TURNS=24
AGENT_MAX_BUDGET_USD=1.0
# Context window the model supports — drives the budget gauge + compaction triggers.
AGENT_CONTEXT_TOKENS=65536
# Max transient-failure retries per model call (exponential backoff).
AGENT_MAX_RETRIES=8

# ── Optional toggles ──
# Use the offline stub model instead of a real provider (no API key needed): 1 / true
# AGENT_FAKE_MODEL=0
# Enable the WebSearch / WebFetch tools (off by default): 1 / true
# AGENT_WEB=0
# Activate a named output style at startup (see <repo>/.zephyrcode/output-styles/<name>.md).
# AGENT_OUTPUT_STYLE=

# ── Persistence & misc ──
# Home for global config + per-project state (sessions, memory). Default: ~/.zephyrcode
# ZEPHYRCODE_HOME=~/.zephyrcode
# Global kill switch for settings.json command hooks: 1 / true
# ZEPHYRCODE_DISABLE_HOOKS=0
